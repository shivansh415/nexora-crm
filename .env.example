# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── WhatsApp Business API ────────────────────────────────────────────────────
# Get these from Meta Developer Console
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_VERIFY_TOKEN=your-random-verify-token

# Outreach template used by the Broadcast feature (first cold message to ad leads).
# Must match an APPROVED template in Meta. Body must use {{1}}=lead name, {{2}}=agent name.
WHATSAPP_TEMPLATE_NAME=ad_lead_message
WHATSAPP_TEMPLATE_LANG=en
WHATSAPP_AGENT_NAME=Shivansh
# Set to "false" if the template body has NO {{1}}/{{2}} variables (e.g. hello_world).
WHATSAPP_TEMPLATE_HAS_VARS=true

# Re-engagement template — used to REOPEN a chat whose 24h window has closed
# ("Reopen with template" action in the chat + /api/conversations/reengage).
# Defaults to the outreach template above. For best delivery/pacing, approve a
# dedicated UTILITY template and set its name here.
WHATSAPP_REENGAGE_TEMPLATE_NAME=ad_lead_message
WHATSAPP_REENGAGE_TEMPLATE_LANG=en
WHATSAPP_REENGAGE_TEMPLATE_HAS_VARS=true

# ─── AI Configuration ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ─── n8n Webhook ──────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/crm

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==============================================================================
# n8n ENVIRONMENT VARIABLES (set these INSIDE n8n, not in this CRM .env)
# The workflow's "Send Guard" (duplicate-send protection) and "Check AI Paused"
# nodes read these from n8n's own environment:
#   SUPABASE_URL=https://<your-project>.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY=<your service role key>
#   SUPABASE_SERVICE_KEY=<same service role key>   # legacy name used by CRM reply path
# In n8n Cloud: Settings -> Variables. Self-hosted: OS env vars / docker -e.
# ==============================================================================
